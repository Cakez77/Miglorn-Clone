CompileFlags:
  Add:
    - "-DSDL3"
    - "-DENGINE"
    - "-DDEBUG"
    - "-DWEB_BUILD"
    - "-DNOMINMAX"
    - "-ferror-limit=0"
    - "-std=c++20"

    - "-I../third_party"
    - "-I../third_party/include"
    - "-I../assets/shaders"

    - "-Wno-writable-strings"
    - "-Wno-sign-compare"
    - "-Wno-deprecated-declarations"
    - "-Wno-format-security"
    - "-Wno-switch"
    - "-Wno-c99-designator"
